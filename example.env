# Telegram
API_ID=
API_HASH=
SESSION_STRING=
SOURCE_GROUP_ID=
DEST_GROUP_ID=

# Database (optional — defaults to SQLite at app/data/messages.db)
# Switch to Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# Redis (optional — defaults to redis://localhost:6379)
# In Docker this is set automatically via docker-compose environment
REDIS_URL=

# Dry run modes (optional — set to 1 to enable)
# DRY_RUN_FORWARD=1   # receives messages, logs what would be forwarded, skips actual forward
# DRY_RUN_DB=1        # receives messages, skips Redis enqueue and DB save entirely

# Logging (optional — default: INFO)
LOG_LEVEL=INFO
# DB_LOG_LEVEL=DEBUG   # separate control for aiosqlite/sqlalchemy logs (default: WARNING)
